# =============================================================================
# EduTutor Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# All settings here are read by backend/api/config.py via pydantic-settings

# --- LLM Provider Configuration ---
# Supported providers: openai, anthropic, gemini, openrouter, cerebras
# The backend uses the OpenAI SDK, so any OpenAI-compatible API works

# Cerebras (default for this project)
CEREBRAS_API_KEY=your-cerebras-api-key-here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Model ID (must match your provider)
# Cerebras: gpt-oss-120b
# OpenAI: gpt-4o, gpt-4o-mini
# Anthropic: claude-sonnet-4-20250514
# OpenRouter: provider/model-name
MODEL_ID=gpt-oss-120b

# Alternative: OpenAI-compatible provider
# OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Data Paths ---
COMPILED_DIR=data/compiled

# --- Retrieval ---
RETRIEVAL_STRATEGY=bm25f
TOP_K=5
USE_REPOSITORY=true

# --- Generation ---
TEMPERATURE=0.0
SEED=0

# --- Verification Thresholds ---
MIN_GROUNDING_COVERAGE=0.6
MIN_COMPLETENESS=0.6
STRICT_VERIFICATION=false

# --- Server ---
HOST=0.0.0.0
PORT=8000
